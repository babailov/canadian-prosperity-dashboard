{
  "name": "canadian-prosperity-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx scripts/seed.ts",
    "db:migrate": "wrangler d1 execute canadian-prosperity-db --local --file=migrations/0001_initial.sql",
    "db:seed": "wrangler d1 execute canadian-prosperity-db --local --file=migrations/0002_seed.sql",
    "dev:vinext": "vite dev --port 3001",
    "build:vinext": "vite build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-rsc": "^0.5.21",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vinext": "^0.0.13",
    "vite": "^7.3.1",
    "wrangler": "^4.69.0"
  },
  "type": "module"
}
